{
    "manifest_version": 3,
    "name": "__MSG_extName__",
    "version": "2.2",
    "description": "__MSG_extDescription__",
    "default_locale": "en",
    "browser_specific_settings": {
        "gecko": {
            "id": "ncku-moodle-keeper@bigbluew.github"
        }
    },
    "icons": {
        "16": "icons/16.png",
        "32": "icons/32.png",
        "48": "icons/48.png",
        "128": "icons/128.png"
    },
    "content_scripts": [
        {
            "matches": ["*://*.ncku.edu.tw/*"],
            "js": ["session_keeper.js", "captcha.js"],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["templates.json", "templates2.json"],
            "matches": ["*://*.ncku.edu.tw/*"]
        }
    ]
}
