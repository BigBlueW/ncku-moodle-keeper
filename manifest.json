{
  "manifest_version": 3,
  "name": "NCKU Moodle Session Keeper",
  "version": "1.2",
  "description": "自動延長連線時間，並自動辨識並輸入 Moodle 驗證碼（本地 OCR）。",
  "content_scripts": [
    {
      "matches": [
        "https://moodle.ncku.edu.tw/*"
      ],
      "js": [
        "vendor/tesseract.min.js",
        "session_keeper.js",
        "captcha.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/*"
      ],
      "matches": [
        "https://moodle.ncku.edu.tw/*"
      ]
    }
  ],
  "permissions": [
    "storage"
  ]
}